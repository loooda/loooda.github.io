rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validation patterns
    function isValidUserProfile(data, userId) {
      return data.uid == userId
        && data.email is string
        && data.email.size() <= 256
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 512))
        && (!('favoriteCategories' in data) || (data.favoriteCategories is list && data.favoriteCategories.size() <= 20))
        && (!('notificationsEnabled' in data) || data.notificationsEnabled is bool)
        && (!('selectedLanguage' in data) || (data.selectedLanguage is string && (data.selectedLanguage == 'ar' || data.selectedLanguage == 'en')))
        && (!('theme' in data) || (data.theme is string && (data.theme == 'light' || data.theme == 'dark')))
        && (!('enableLocationNews' in data) || data.enableLocationNews is bool);
    }

    function isValidNotificationItem(data) {
      return data.id is string
        && data.id.size() <= 128
        && data.title is string
        && data.title.size() <= 256
        && data.message is string
        && data.message.size() <= 1024
        && data.type is string
        && (data.type == 'breaking' || data.type == 'local' || data.type == 'personalized')
        && data.read is bool;
    }

    // Match rules for users
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidUserProfile(request.resource.data, userId)
        && request.resource.data.keys().hasAll(['uid', 'email'])
        && request.resource.data.keys().size() >= 2;
        
      allow update: if isOwner(userId)
        && isValidUserProfile(request.resource.data, userId)
        // Make sure uid and email are immutable
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email;
        
      allow delete: if false; // Users cannot be deleted from frontend for security

      // Subcollection for notifications
      match /notifications/{notificationId} {
        allow list, get: if isOwner(userId);
        
        allow create: if isOwner(userId)
          && isValidNotificationItem(request.resource.data)
          && request.resource.data.keys().hasAll(['id', 'title', 'message', 'type', 'read'])
          && request.resource.data.keys().size() >= 5;
          
        allow update: if isOwner(userId)
          && isValidNotificationItem(request.resource.data)
          // Make sure notification content itself doesn't change, they can only modify 'read'
          && request.resource.data.id == resource.data.id
          && request.resource.data.title == resource.data.title
          && request.resource.data.message == resource.data.message
          && request.resource.data.type == resource.data.type
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
          
        allow delete: if isOwner(userId);
      }
    }
  }
}
